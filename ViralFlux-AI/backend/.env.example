# Database
DATABASE_URL="postgresql://user:password@localhost:5432/viralflux?schema=public"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# Encryption
ENCRYPTION_KEY="your-32-char-encryption-key"

# Auth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI Providers
OPENAI_API_KEY=""
ASSEMBLYAI_API_KEY=""
REPLICATE_API_KEY=""
RUNWAY_API_KEY=""

# Storage
STORAGE_PROVIDER="s3" # s3, cloudinary, local
S3_BUCKET="viralflux-videos"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Billing Provider
BILLING_PROVIDER="lemonsqueezy" # lemonsqueezy, paddle, paypal, etc.
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Server
PORT=4000
NODE_ENV="development"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Queue
REDIS_URL="redis://localhost:6379"

# Video Processing
MAX_FILE_SIZE=5368709120 # 5GB
VIDEO_PROCESSING_TIMEOUT=600000 # 10 min
